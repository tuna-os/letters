#: data/net.codelogistics.letters.metainfo.xml.in:8
msgid "Word processor for GNOME"
msgstr "Procesor tekstu dla GNOME"

#: data/net.codelogistics.letters.metainfo.xml.in:10
msgid ""
"Letters is a modern, minimalist word processor for the GNOME desktop, with "
"support for reading and writing DOCX, ODT, MD and HTML files. It can also "
"export your documents as a PDF file."
msgstr ""
"Litery to nowoczesny, minimalistyczny procesor tekstu dla biurka GNOME ze "
"wsparciem dla czytania i zapisywania plików DOCX, ODT, MD i HTML. Może także "
"wyeksportować twoje dokumenty do pliku PDF."

