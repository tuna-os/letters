using Gtk 4.0;
using Adw 1;

StringList styles_list {
  strings [_("Paragraph"), _("Heading 1"), _("Heading 2"), _("Heading 3"), _("Heading 4"), _("Heading 5"), _("Heading 6"), _("Code"), _("Quote")]
}

template $LettersWindow: Adw.ApplicationWindow {
  title: _("Letters");
  default-width: 800;
  default-height: 600;
  height-request: 360;
  width-request: 296;

  content: Adw.ToolbarView tbview {
    top-bar-style: raised;
    [top]
    Adw.HeaderBar {
      [start]
      Button add_button {
        icon-name: "list-add";
        tooltip-text: _("New Document");
      }

      [end]
      MenuButton {
        primary: true;
        icon-name: "open-menu-symbolic";
        tooltip-text: _("Main Menu");
        menu-model: primary_menu;
      }
    }

    [top]
    Adw.TabBar tabbar {
      view: tabview;
    }

    [top]
      Box toolbar{
        css-classes: ['toolbar'];
        halign: center;

        ToggleButton bold_button {
          icon-name: "text-bold-symbolic";
          tooltip-text: _("Bold");
        }

        ToggleButton italic_button {
          icon-name: "text-italic-symbolic";
          tooltip-text: _("Italic");
        }

        ToggleButton underline_button {
          icon-name: "text-underline-symbolic";
          tooltip-text: _("Underline");
        }

        MenuButton {
          tooltip-text: _("Formatting Options");
          menu-model: formatting_menu;
          direction: down;
        }

        MenuButton {
          icon-name: "list-add-symbolic";
          tooltip-text: _("Insert...");
          menu-model: insert_menu;
          direction: down;
        }

        DropDown styles_dropdown{
          tooltip-text: _("Paragraph Style");
          model: styles_list;
        }
      }

    content: Stack stack {
      [child]
      StackPage {
        child: Adw.TabView tabview {};
      }

      [child]
      StackPage {
        child: Adw.StatusPage statuspage{
          icon-name: _("document-new-symbolic");
          title: _("Create a new document");
          description: _("Create a new document (Ctrl + N), or open an existing one (Ctrl + O)");
        };
      }
    };
  };
}

menu primary_menu {
  section {
    item {
      label: _("Open");
      action: "app.open";
    }
    item {
      label: _("Save");
      action: "app.save";
    }
    item (_("Save As"), "app.save_as")
  }
  section {
    item {
      label: _("Print");
      action: "app.print";
    }

    item {
      label: _("Export to PDF");
      action: "app.export";
    }
  }
  section {
    item {
      label: _("_Keyboard Shortcuts");
      action: "app.shortcuts";
    }

    item {
      label: _("_About Letters");
      action: "app.about";
    }
  }
}

menu insert_menu {
  section {
    item {
      label: _("Insert Image");
      action: "app.insertimage";
    }
    item {
      label: _("Insert Link");
      action: "app.insertlink";
    }
    item {
      label: _("Insert List");
      action: "app.insertlist";
    }
  }
}

menu formatting_menu{
    item {
      label: _("Strikethrough");
      action: "app.strikethrough";
    }
    item {
      label: _("Highlight");
      action: "app.highlight";
    }
    item {
      label: _("Increase Indent");
      action: "app.indent";
    }
    item {
      label: _("Decrease Indent");
      action: "app.outdent";
    }
}