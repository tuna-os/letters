<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.hanthor.letters</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Letters</name>
  <summary>Word processor for GNOME</summary>
  <description>
    <p>Letters is a modern, minimalist word processor for the GNOME desktop, with support
      for reading and writing DOCX, ODT, MD and HTML files.
      It can also export your documents as a PDF file.</p>
  </description>

  <developer id="io.github.hanthor">
    <name>Satvik Patwardhan</name>
  </developer>

  <categories>
    <category>Office</category>
    <category>Utility</category>
  </categories>

  <!-- Required: Should be a link to the upstream homepage for the component -->
  <url type="homepage">https://github.com/hanthor/letters</url>
  <url type="vcs-browser">https://github.com/hanthor/letters</url>
  <url type="bugtracker">https://github.com/hanthor/letters/issues</url>
  <url type="help">https://github.com/hanthor/letters#readme</url>

  <translation type="gettext">letters</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">io.github.hanthor.letters.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#ffffff</color>
    <color type="primary" scheme_preference="dark">#000000</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://codeberg.org/eyekay/letters/raw/branch/main/screenshot.png</image>
      <caption>Screenshot of Letters</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.2.0" date="2025-10-24">
      <description translate="no">
        <ul>
          <li>New formatting features: strikethrough, highlight, indent and outdent</li>
          <li>Added support for exporting to RTF</li>
          <li>Fixed HTML and TXT import</li>
          <li>New icon (Jakub Steiner)</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2025-10-03">
      <description translate="no">
        <p>First release</p>
      </description>
    </release>
  </releases>

</component>
